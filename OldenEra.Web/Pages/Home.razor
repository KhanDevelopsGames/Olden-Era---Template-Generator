@page "/"
@inject FileDownloader Downloader

<PageTitle>Olden Era - Template Generator</PageTitle>

<div class="oe-app">
    <div class="oe-title-bar">
        <h1>Olden Era — Simple Template Generator</h1>
        <span class="oe-version-badge">@VersionLabel</span>
    </div>

    <div class="oe-warning">
        ⚠️ Work in progress — some generated templates may contain game-breaking bugs or issues.
    </div>

    <div class="oe-grid">
        <div>
            <div class="oe-columns">
                <!-- TEMPLATE -->
                <div class="oe-section">
                    <div class="oe-section-header">◆ Template</div>

                    <div class="oe-stacked">
                        <label class="oe-label" for="tplname">Template Name</label>
                        <input id="tplname" type="text"
                               value="@Settings.TemplateName"
                               @oninput="OnTemplateNameInput" />
                    </div>

                    <div class="oe-stacked">
                        <label class="oe-label" for="mapsize">Map Size</label>
                        <select id="mapsize" @bind="MapSize" @bind:after="OnChanged">
                            @foreach (int size in AvailableMapSizes)
                            {
                                <option value="@size">@FormatMapSize(size)</option>
                            }
                        </select>
                    </div>

                    <label class="oe-check">
                        <input type="checkbox" checked="@ExperimentalMapSizes"
                               @onchange="OnExperimentalToggled" />
                        <span>Experimental large map sizes</span>
                    </label>
                    @if (ExperimentalMapSizes)
                    {
                        <div class="oe-hint">
                            Adds 256x256 through 512x512. Official templates top out at 240x240,
                            so larger maps may fail, freeze, or behave unpredictably in game.
                        </div>
                    }

                    <SliderRow Label="Players"
                               Min="2" Max="8" Step="1"
                               Value="Settings.PlayerCount"
                               ValueChanged="@(v => { Settings.PlayerCount = (int)v; OnChanged(); })" />
                </div>

                <!-- HEROES -->
                <HeroSettingsPanel Settings="Settings" OnChanged="OnChanged" />
            </div>

            <TopologyPicker Settings="Settings" OnChanged="OnChanged" />

            <ZoneConfigPanel Settings="Settings"
                             AdvancedMode="AdvancedMode"
                             AdvancedModeChanged="OnAdvancedModeChanged"
                             OnChanged="OnChanged" />

            <AdvancedPanel Settings="Settings"
                           AdvancedMode="AdvancedMode"
                           OnChanged="OnChanged" />

            <WinConditionsPanel Settings="Settings" OnChanged="OnChanged" />
        </div>

        <div class="oe-preview-col">
            <button class="oe-btn primary"
                    disabled="@(!IsValid)"
                    @onclick="Generate">
                ⚔ Generate Template
            </button>
            @if (!string.IsNullOrEmpty(ValidationMessage))
            {
                <div class="oe-error">@ValidationMessage</div>
            }

            <PreviewPanel PngBytes="PreviewPng" />

            <button class="oe-btn"
                    disabled="@(GeneratedTemplate is null)"
                    @onclick="DownloadJson">
                💾 Download .rmg.json
            </button>
            <button class="oe-btn"
                    disabled="@(PreviewPng is null)"
                    @onclick="DownloadPng">
                🖼 Download Preview PNG
            </button>
        </div>
    </div>
</div>

@code {
    private static readonly System.Text.Json.JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull,
    };

    private GeneratorSettings Settings { get; set; } = new();
    private bool AdvancedMode { get; set; }
    private bool ExperimentalMapSizes { get; set; }

    private OldenEra.Generator.Models.Unfrozen.RmgTemplate? GeneratedTemplate;
    private byte[]? PreviewPng;

    private string ValidationMessage = "";
    private bool IsValid = true;

    private string VersionLabel = "v1.0";

    protected override void OnInitialized()
    {
        var version = System.Reflection.Assembly.GetExecutingAssembly().GetName().Version;
        if (version is not null)
            VersionLabel = version.Build > 0
                ? $"v{version.Major}.{version.Minor}.{version.Build}"
                : $"v{version.Major}.{version.Minor}";
        Validate();
    }

    private int MapSize
    {
        get => Settings.MapSize;
        set => Settings.MapSize = value;
    }

    private IEnumerable<int> AvailableMapSizes =>
        ExperimentalMapSizes ? KnownValues.AllMapSizes : KnownValues.MapSizes;

    private static string FormatMapSize(int size) =>
        KnownValues.IsExperimentalMapSize(size)
            ? $"{size}x{size} ({KnownValues.MapSizeLabel(size)}) (Experimental)"
            : $"{size}x{size} ({KnownValues.MapSizeLabel(size)})";

    private void OnTemplateNameInput(ChangeEventArgs e)
    {
        Settings.TemplateName = e.Value?.ToString() ?? "";
        Validate();
    }

    private void OnExperimentalToggled(ChangeEventArgs e)
    {
        ExperimentalMapSizes = (bool)e.Value!;
        if (!ExperimentalMapSizes && KnownValues.IsExperimentalMapSize(Settings.MapSize))
            Settings.MapSize = KnownValues.MaxOfficialMapSize;
        Validate();
    }

    private void OnAdvancedModeChanged(bool advanced)
    {
        AdvancedMode = advanced;
        Settings.ZoneCfg.Advanced.Enabled = advanced;
        Validate();
    }

    private void OnChanged()
    {
        Validate();
        StateHasChanged();
    }

    private int TotalNeutralZones()
    {
        if (!AdvancedMode) return Settings.ZoneCfg.NeutralZoneCount;
        var a = Settings.ZoneCfg.Advanced;
        return a.NeutralLowNoCastleCount + a.NeutralLowCastleCount
             + a.NeutralMediumNoCastleCount + a.NeutralMediumCastleCount
             + a.NeutralHighNoCastleCount + a.NeutralHighCastleCount;
    }

    /// <summary>Hard-blocker validation. Mirrors the early returns from MainWindow.Validate().</summary>
    private void Validate()
    {
        const int MaxZones = 32;

        var hero = Settings.HeroSettings;
        if (hero.HeroCountMin > hero.HeroCountMax)
        {
            Fail("Min Heroes cannot be greater than Max Heroes."); return;
        }

        int neutral = TotalNeutralZones();
        if (Settings.PlayerCount + neutral > MaxZones)
        {
            Fail($"Total zones (players + neutral) cannot exceed {MaxZones}."); return;
        }

        if (string.IsNullOrWhiteSpace(Settings.TemplateName))
        {
            Fail("Template name cannot be empty."); return;
        }

        if (Settings.GameEndConditions.CityHold
            && Settings.Topology != MapTopology.HubAndSpoke
            && neutral == 0)
        {
            Fail("City Hold requires at least one neutral zone. Add a neutral zone or switch to the Hub layout."); return;
        }

        if (Settings.NoDirectPlayerConnections && neutral == 0)
        {
            Fail("\"Connect via neutral zones only\" requires at least one neutral zone."); return;
        }

        if (Settings.GameEndConditions.VictoryCondition == "win_condition_6"
            && Settings.PlayerCount != 2)
        {
            Fail("Tournament mode only supports exactly 2 players."); return;
        }

        IsValid = true;
        ValidationMessage = "";
    }

    private void Fail(string msg)
    {
        IsValid = false;
        ValidationMessage = msg;
    }

    private void Generate()
    {
        if (!IsValid) return;
        // Make sure advanced flag in payload reflects UI mode.
        Settings.ZoneCfg.Advanced.Enabled = AdvancedMode;
        if (!AdvancedMode)
        {
            Settings.MinNeutralZonesBetweenPlayers = 0;
            Settings.ZoneCfg.Advanced.PlayerZoneSize = 1.0;
            Settings.ZoneCfg.Advanced.NeutralZoneSize = 1.0;
            Settings.ZoneCfg.Advanced.GuardRandomization = 0.05;
        }

        GeneratedTemplate = TemplateGenerator.Generate(Settings);
        PreviewPng = TemplatePreviewRenderer.RenderPng(GeneratedTemplate, Settings.Topology);
    }

    private async Task DownloadJson()
    {
        if (GeneratedTemplate is null) return;
        byte[] bytes = System.Text.Json.JsonSerializer.SerializeToUtf8Bytes(GeneratedTemplate, JsonOptions);
        string name = string.IsNullOrWhiteSpace(Settings.TemplateName) ? "Custom Template" : Settings.TemplateName.Trim();
        await Downloader.DownloadAsync($"{name}.rmg.json", "application/json", bytes);
    }

    private async Task DownloadPng()
    {
        if (PreviewPng is null) return;
        string name = string.IsNullOrWhiteSpace(Settings.TemplateName) ? "Custom Template" : Settings.TemplateName.Trim();
        await Downloader.DownloadAsync($"{name}.png", "image/png", PreviewPng);
    }
}
