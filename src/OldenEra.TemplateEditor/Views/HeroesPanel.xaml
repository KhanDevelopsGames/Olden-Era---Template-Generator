<UserControl x:Class="OldenEra.TemplateEditor.Views.HeroesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource OeTextDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>
    <Border Style="{StaticResource SectionBorder}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Heroes" Style="{StaticResource SectionHeader}"/>
                <TextBlock Text="Maximum heroes a player may hire; increases with each captured castle."
                           TextWrapping="Wrap" Foreground="#888" FontStyle="Italic" Margin="5,2,5,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Grid.Column="0">
                        <Label Content="Heroes per player (min)" Padding="5,2" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="TxtHeroMin" Text="4" DockPanel.Dock="Right"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                    </DockPanel>
                    <Slider Grid.Row="0" Grid.Column="1" x:Name="SldHeroMin"
                            Minimum="1" Maximum="12" Value="4"
                            TickFrequency="1" IsSnapToTickEnabled="True"/>

                    <DockPanel Grid.Row="2" Grid.Column="0">
                        <Label Content="Heroes per player (max)" Padding="5,2" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="TxtHeroMax" Text="8" DockPanel.Dock="Right"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                    </DockPanel>
                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldHeroMax"
                            Minimum="1" Maximum="12" Value="8"
                            TickFrequency="1" IsSnapToTickEnabled="True"/>

                    <DockPanel Grid.Row="4" Grid.Column="0">
                        <Label Content="Bonus heroes per extra castle" Padding="5,2" DockPanel.Dock="Left"/>
                        <TextBlock x:Name="TxtHeroIncrement" Text="1" DockPanel.Dock="Right"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                    </DockPanel>
                    <Slider Grid.Row="4" Grid.Column="1" x:Name="SldHeroIncrement"
                            Minimum="0" Maximum="10" Value="1"
                            TickFrequency="1" IsSnapToTickEnabled="True"/>
                </Grid>

                <Expander Header="Ban specific heroes" Margin="0,8,0,4">
                    <StackPanel Margin="8,4,0,8">
                        <TextBlock Style="{StaticResource HintText}">
                            Banned heroes are removed from the template's hero pool (emitted as globalBans.heroes).
                        </TextBlock>
                        <TabControl x:Name="TcHeroBans" Margin="0,4,0,0" MinHeight="180"/>
                    </StackPanel>
                </Expander>

                <Expander Header="Pin starting hero per faction" Margin="0,4,0,4">
                    <StackPanel Margin="8,4,0,8">
                        <TextBlock Style="{StaticResource HintText}">
                            Optional. The .rmg.json schema does not currently expose a pinned-hero
                            field on player Spawn objects, so this setting round-trips in .oetgs
                            but is not emitted into the generated template.
                        </TextBlock>
                        <ItemsControl x:Name="IcFixedHeroes" Margin="0,4,0,0"/>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
