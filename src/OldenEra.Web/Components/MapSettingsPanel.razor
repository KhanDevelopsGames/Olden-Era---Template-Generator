@* Template name, map size, experimental sizes toggle, player count. *@

<div class="oe-section">
    <div class="oe-section-header">Template</div>

    <div class="oe-stacked">
        <label class="oe-label" for="tplname">Template Name</label>
        <input id="tplname" type="text"
               value="@Settings.TemplateName"
               @oninput="OnTemplateNameInput" />
    </div>

    <div class="oe-stacked">
        <label class="oe-label" for="mapsize">Map Size</label>
        <select id="mapsize" @bind="MapSize" @bind:after="NotifyChanged">
            @foreach (int size in AvailableMapSizes)
            {
                <option value="@size">@FormatMapSize(size)</option>
            }
        </select>
    </div>

    <div class="oe-stacked">
        <label class="oe-label" for="seed">Seed</label>
        <div class="oe-seed-row">
            <input id="seed" type="number"
                   title="Optional integer seed. Leave blank for non-deterministic generation."
                   value="@SeedText"
                   @oninput="OnSeedInput" />
            <button type="button"
                    class="oe-btn oe-seed-dice"
                    title="Generate a new random seed (reproducible output for the same seed)"
                    @onclick="RandomizeSeed">🎲</button>
        </div>
    </div>

    <label class="oe-check">
        <input type="checkbox" checked="@ExperimentalMapSizes"
               @onchange="OnExperimentalCheckboxChanged" />
        <span>Experimental large map sizes</span>
        <ExperimentalBadge />
    </label>
    @if (ExperimentalMapSizes)
    {
        <div class="oe-hint">
            Adds 256x256 through 512x512. Official templates top out at 240x240,
            so larger maps may fail, freeze, or behave unpredictably in game.
        </div>
    }

    <SliderRow Label="Players"
               Min="2" Max="8" Step="1"
               Value="Settings.PlayerCount"
               ValueChanged="@(v => { Settings.PlayerCount = (int)v; OnChanged.InvokeAsync(); })" />
</div>

@code {
    [Parameter, EditorRequired] public GeneratorSettings Settings { get; set; } = default!;
    [Parameter] public bool ExperimentalMapSizes { get; set; }
    [Parameter] public EventCallback<bool> ExperimentalMapSizesChanged { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private int MapSize
    {
        get => Settings.MapSize;
        set => Settings.MapSize = value;
    }

    private IEnumerable<int> AvailableMapSizes =>
        ExperimentalMapSizes ? KnownValues.AllMapSizes : KnownValues.MapSizes;

    private static string FormatMapSize(int size) =>
        KnownValues.IsExperimentalMapSize(size)
            ? $"{size}x{size} ({KnownValues.MapSizeLabel(size)}) (Experimental)"
            : $"{size}x{size} ({KnownValues.MapSizeLabel(size)})";

    private async Task OnTemplateNameInput(ChangeEventArgs e)
    {
        Settings.TemplateName = e.Value?.ToString() ?? "";
        await OnChanged.InvokeAsync();
    }

    private string SeedText => Settings.Seed?.ToString() ?? "";

    private async Task OnSeedInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        Settings.Seed = int.TryParse(raw, out var v) ? v : (int?)null;
        await OnChanged.InvokeAsync();
    }

    private async Task RandomizeSeed()
    {
        Settings.Seed = Random.Shared.Next(0, int.MaxValue);
        await OnChanged.InvokeAsync();
    }

    private async Task OnExperimentalCheckboxChanged(ChangeEventArgs e)
    {
        bool value = (bool)e.Value!;
        await ExperimentalMapSizesChanged.InvokeAsync(value);
        await OnChanged.InvokeAsync();
    }

    private Task NotifyChanged() => OnChanged.InvokeAsync();
}
