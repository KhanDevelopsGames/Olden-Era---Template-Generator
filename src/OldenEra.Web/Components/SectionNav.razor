@typeparam TSection where TSection : struct, Enum

<nav class="oe-nav-list">
    @foreach (var section in VisibleSections)
    {
        var label = SectionLabel(section);
        var active = EqualityComparer<TSection>.Default.Equals(section, Active);
        <button type="button"
                class="oe-nav-item @(active ? "active" : "")"
                @onclick="() => OnSelect(section)">
            @label
        </button>
    }
</nav>

<select class="oe-nav-select"
        value="@ActiveString"
        @onchange="OnSelectChange">
    @foreach (var section in VisibleSections)
    {
        <option value="@(section.ToString())">@SectionLabel(section)</option>
    }
</select>

@if (!string.IsNullOrEmpty(ValidationMessage))
{
    <div class="oe-nav-footer">
        <span class="oe-nav-issue-dot" aria-hidden="true"></span>
        @ValidationMessage
    </div>
}

@code {
    [Parameter] public TSection Active { get; set; } = default!;
    [Parameter] public EventCallback<TSection> ActiveChanged { get; set; }
    [Parameter] public Func<TSection, string>? LabelFor { get; set; }
    [Parameter] public Func<TSection, bool>? Visible { get; set; }
    [Parameter] public string? ValidationMessage { get; set; }

    private IEnumerable<TSection> VisibleSections =>
        Visible is null ? Enum.GetValues<TSection>() : Enum.GetValues<TSection>().Where(Visible);

    private string SectionLabel(TSection s) => LabelFor?.Invoke(s) ?? s.ToString();

    private string ActiveString => Active.ToString();

    private async Task OnSelect(TSection s)
    {
        if (EqualityComparer<TSection>.Default.Equals(s, Active)) return;
        Active = s;
        await ActiveChanged.InvokeAsync(s);
    }

    private async Task OnSelectChange(ChangeEventArgs e)
    {
        if (e.Value is not string s) return;
        if (Enum.TryParse<TSection>(s, out var parsed))
        {
            Active = parsed;
            await ActiveChanged.InvokeAsync(parsed);
        }
    }
}
