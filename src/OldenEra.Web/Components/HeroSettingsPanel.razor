@* Hero count min / max / increment, plus per-faction ban list. *@

<div class="oe-section">
    <div class="oe-section-header">Heroes</div>
    <div class="oe-hint">Maximum heroes a player may hire; increases with each captured castle.</div>

    <SliderRow Label="Heroes per player (min)"
               Min="1" Max="12" Step="1"
               Value="Settings.HeroSettings.HeroCountMin"
               ValueChanged="@(v => { Settings.HeroSettings.HeroCountMin = (int)v; NotifyChanged(); })" />

    <SliderRow Label="Heroes per player (max)"
               Min="1" Max="12" Step="1"
               Value="Settings.HeroSettings.HeroCountMax"
               ValueChanged="@(v => { Settings.HeroSettings.HeroCountMax = (int)v; NotifyChanged(); })" />

    <SliderRow Label="Bonus heroes per extra castle"
               Min="0" Max="10" Step="1"
               Value="Settings.HeroSettings.HeroCountIncrement"
               ValueChanged="@(v => { Settings.HeroSettings.HeroCountIncrement = (int)v; NotifyChanged(); })" />

    <details class="oe-stacked" style="margin-top: 12px;">
        <summary class="oe-label" style="cursor: pointer;">
            Ban specific heroes (@Settings.HeroSettings.HeroBans.Count selected)
        </summary>
        <div class="oe-hint">
            Banned heroes are removed from the template's hero pool
            (emitted as <code>globalBans.heroes</code>).
        </div>

        <div class="oe-tier-tabs" role="tablist">
            @foreach (var faction in Catalog.Factions)
            {
                <button type="button"
                        class="@($"oe-tier-tab{(ActiveFactionId == faction.Id ? " active" : "")}")"
                        role="tab"
                        aria-selected="@(ActiveFactionId == faction.Id ? "true" : "false")"
                        @onclick="@(() => ActiveFactionId = faction.Id)">
                    @faction.Name
                </button>
            }
        </div>

        <div class="oe-ban-chips">
            @foreach (var hero in Catalog.HeroesByFaction(ActiveFactionId).OrderBy(h => h.Name))
            {
                bool banned = Settings.HeroSettings.HeroBans.Contains(hero.Id);
                var tooltip = string.IsNullOrWhiteSpace(hero.Specialty)
                    ? hero.Id
                    : $"{hero.Specialty}: {hero.SpecialtyDescription ?? ""}".Trim().TrimEnd(':');
                <button type="button"
                        class="@($"oe-ban-chip{(banned ? " selected" : "")}")"
                        title="@tooltip"
                        @onclick="@(() => ToggleHeroBan(hero.Id))">
                    @hero.Name
                </button>
            }
        </div>
    </details>

    <details class="oe-stacked" style="margin-top: 12px;">
        <summary class="oe-label" style="cursor: pointer;">
            Pin starting hero per faction
        </summary>
        <div class="oe-hint">
            Optional. UI-only at this time: the .rmg.json schema does not currently
            expose a pinned-hero field on player Spawn objects, so this setting is
            saved in your <code>.oetgs</code> file but not emitted into the
            generated template.
        </div>

        @foreach (var faction in Catalog.Factions)
        {
            var current = GetFixedHero(faction.Id);
            <div class="oe-row" style="grid-template-columns: 140px 1fr;">
                <label class="oe-label" style="margin: 0;">@faction.Name</label>
                <select value="@current"
                        @onchange="@(e => OnFixedHeroChanged(faction.Id, e))">
                    <option value="">(Random)</option>
                    @foreach (var hero in Catalog.HeroesByFaction(faction.Id)
                                                  .Where(h => !Settings.HeroSettings.HeroBans.Contains(h.Id))
                                                  .OrderBy(h => h.Name))
                    {
                        <option value="@hero.Id">@hero.Name@(string.IsNullOrWhiteSpace(hero.Specialty) ? "" : $" — {hero.Specialty}")</option>
                    }
                </select>
            </div>
        }
    </details>

    <details class="oe-stacked" style="margin-top: 12px;">
        <summary class="oe-label" style="cursor: pointer;">
            Ban specific spells (@Settings.HeroSettings.BannedSpells.Count selected)
        </summary>
        <div class="oe-hint">
            Banned spells are removed from mage guilds, shrines, and pandora boxes
            (emitted as <code>globalBans.magics</code>).
        </div>

        <div class="oe-tier-tabs" role="tablist">
            @foreach (var school in SpellSchools)
            {
                <button type="button"
                        class="@($"oe-tier-tab{(ActiveSchool == school ? " active" : "")}")"
                        role="tab"
                        aria-selected="@(ActiveSchool == school ? "true" : "false")"
                        @onclick="@(() => ActiveSchool = school)">
                    @FriendlySchool(school)
                </button>
            }
        </div>

        <div class="oe-ban-chips">
            @foreach (var spell in SpellsBySchool(ActiveSchool))
            {
                bool banned = Settings.HeroSettings.BannedSpells.Contains(spell.Id);
                var tooltip = string.IsNullOrWhiteSpace(spell.Description)
                    ? $"T{spell.Tier} · {FriendlySchool(spell.School)}"
                    : spell.Description;
                <button type="button"
                        class="@($"oe-ban-chip{(banned ? " selected" : "")}")"
                        title="@tooltip"
                        @onclick="@(() => ToggleSpellBan(spell.Id))">
                    @($"T{spell.Tier}. {spell.Name}")
                </button>
            }
        </div>
    </details>
</div>

@code {
    [Parameter, EditorRequired] public GeneratorSettings Settings { get; set; } = default!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private static CommunityCatalog Catalog => CommunityCatalog.Default;
    private string ActiveFactionId { get; set; } = Catalog.Factions.FirstOrDefault()?.Id ?? "temple";

    private Task NotifyChanged() => OnChanged.InvokeAsync();

    private async Task ToggleHeroBan(string heroId)
    {
        if (!Settings.HeroSettings.HeroBans.Remove(heroId))
            Settings.HeroSettings.HeroBans.Add(heroId);

        // Clear any pin that points at a now-banned hero so the validator stays clean.
        if (Settings.HeroSettings.HeroBans.Contains(heroId))
        {
            foreach (var key in Settings.HeroSettings.FixedStartingHeroByFaction.Keys.ToList())
            {
                if (string.Equals(Settings.HeroSettings.FixedStartingHeroByFaction[key], heroId, StringComparison.OrdinalIgnoreCase))
                    Settings.HeroSettings.FixedStartingHeroByFaction[key] = null;
            }
        }
        await NotifyChanged();
    }

    private string GetFixedHero(string factionId)
    {
        return Settings.HeroSettings.FixedStartingHeroByFaction.TryGetValue(factionId, out var v) && v is not null
            ? v
            : "";
    }

    private async Task OnFixedHeroChanged(string factionId, ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        Settings.HeroSettings.FixedStartingHeroByFaction[factionId] = string.IsNullOrEmpty(v) ? null : v;
        await NotifyChanged();
    }

    private string ActiveSchool { get; set; } = SpellSchools.FirstOrDefault() ?? "day";

    private static readonly string[] SpellSchools =
        CommunityCatalog.Default.Spells
            .Select(s => s.School ?? "")
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(SchoolOrder)
            .ToArray();

    private static IEnumerable<SpellEntry> SpellsBySchool(string school) =>
        CommunityCatalog.Default.Spells
            .Where(s => string.Equals(s.School, school, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.Tier)
            .ThenBy(s => s.Name, StringComparer.OrdinalIgnoreCase);

    private static int SchoolOrder(string school) => school?.ToLowerInvariant() switch
    {
        "day" => 0,
        "night" => 1,
        "arcane" => 2,
        "primal" => 3,
        _ => 99,
    };

    private static string FriendlySchool(string school) => school?.ToLowerInvariant() switch
    {
        "day" => "Day",
        "night" => "Night",
        "arcane" => "Arcane",
        "primal" => "Primal",
        _ => string.IsNullOrEmpty(school) ? "Other" : char.ToUpper(school[0]) + school[1..],
    };

    private async Task ToggleSpellBan(string spellId)
    {
        if (!Settings.HeroSettings.BannedSpells.Remove(spellId))
            Settings.HeroSettings.BannedSpells.Add(spellId);
        await NotifyChanged();
    }
}
