@page "/"
@inject FileDownloader Downloader
@inject BrowserSettingsStore SettingsStore
@inject UpdateChecker UpdateChecker
@implements IDisposable

<PageTitle>Olden Era - Template Generator</PageTitle>

<div class="oe-app">
    <header class="oe-header">
        <div class="oe-header-left">
            <h1>Olden Era — Simple Template Generator</h1>
            <span class="oe-version-badge">@VersionLabel</span>
        </div>
        <div class="oe-header-actions">
            <label class="oe-check inline" style="margin-right:8px;">
                <input type="checkbox" checked="@AdvancedMode" @onchange="OnAdvancedHeaderToggled" />
                <span>Advanced</span>
            </label>
            <label class="oe-check inline" style="margin-right:8px;">
                <input type="checkbox" checked="@ExperimentalEnabled" @onchange="OnExperimentalEnabledChanged" />
                <span>Experimental</span>
                <ExperimentalBadge />
            </label>
            <button class="oe-btn ghost" @onclick="OpenSettingsClick">Open settings…</button>
            <button class="oe-btn ghost" @onclick="SaveSettingsClick">Save settings…</button>
            <button class="oe-btn ghost" @onclick="ShareSettingsClick">Share link</button>
            @if (!string.IsNullOrEmpty(ShareToast))
            {
                <span class="oe-toast">@ShareToast</span>
            }
            <InputFile id="oeOpenSettingsFile" OnChange="OnSettingsFileSelected"
                       accept=".oetgs,application/json"
                       style="display:none" />
        </div>
    </header>

    <div class="oe-warning">
        ⚠️ Work in progress — some generated templates may contain game-breaking bugs or issues.
    </div>

    @if (UpdateAvailable is not null)
    {
        <div class="oe-update-banner">
            A newer version (<strong>@FormatVersion(UpdateAvailable)</strong>) is available.
            <a href="@UpdateChecker.ReleasesPageUrl" target="_blank" rel="noopener noreferrer">
                Open releases page
            </a>
            <button class="oe-link-btn" @onclick="DismissUpdateBanner" aria-label="Dismiss">✕</button>
        </div>
    }

    <div class="oe-shell">
        <aside class="oe-nav">
            <SectionNav TSection="Section"
                        Active="ActiveSection"
                        ActiveChanged="@(s => ActiveSection = s)"
                        LabelFor="@(s => s switch {
                            Section.Map => "Map",
                            Section.Heroes => "Heroes",
                            Section.Topology => "Topology",
                            Section.Zones => "Zones",
                            Section.WinConditions => "Win Conditions",
                            Section.Experimental => "Experimental ⚗",
                            _ => s.ToString()
                        })"
                        Visible="@(s => s != Section.Experimental || ExperimentalEnabled)"
                        ValidationMessage="@(IsValid ? null : ValidationMessage)" />
        </aside>

        <section class="oe-content">
            @switch (ActiveSection)
            {
                case Section.Map:
                    <MapSettingsPanel Settings="Settings"
                                      ExperimentalMapSizes="ExperimentalMapSizes"
                                      ExperimentalMapSizesChanged="OnExperimentalToggled"
                                      OnChanged="OnChanged" />
                    break;
                case Section.Heroes:
                    <HeroSettingsPanel Settings="Settings" OnChanged="OnChanged" />
                    break;
                case Section.Topology:
                    <TopologyPicker Settings="Settings" OnChanged="OnChanged" />
                    break;
                case Section.Zones:
                    <ZoneConfigPanel Settings="Settings"
                                     AdvancedMode="AdvancedMode"
                                     AdvancedModeChanged="OnAdvancedModeChanged"
                                     OnChanged="OnChanged" />
                    <AdvancedPanel Settings="Settings"
                                   AdvancedMode="AdvancedMode"
                                   OnChanged="OnChanged" />
                    break;
                case Section.WinConditions:
                    <WinConditionsPanel Settings="Settings" OnChanged="OnChanged" />
                    break;
                case Section.Experimental:
                    <div class="oe-section">
                        <div class="oe-section-header">
                            <span>Experimental features <ExperimentalBadge /></span>
                        </div>
                        <div class="oe-hint">
                            These features change template fields the game has not been
                            extensively tested against. Generated maps may behave
                            unpredictably. Each card is collapsed by default — open the
                            ones you want to use.
                        </div>
                    </div>
                    <GameModePanel Settings="Settings" OnChanged="OnChanged" />
                    <StartingBonusesPanel Settings="Settings" OnChanged="OnChanged" />
                    <ExperimentalZonePanel Settings="Settings" OnChanged="OnChanged" />
                    <PerTierOverridesPanel Settings="Settings" OnChanged="OnChanged" />
                    break;
            }
        </section>

        <aside class="oe-preview-col">
            <button class="oe-btn primary"
                    disabled="@(!IsValid || IsGenerating)"
                    @onclick="OnGenerateClick">
                Generate Template
            </button>
            @if (!string.IsNullOrEmpty(ValidationMessage))
            {
                <div class="oe-error">@ValidationMessage</div>
            }

            <PreviewPanel PngBytes="PreviewPng" />

            <button class="oe-btn"
                    disabled="@(GeneratedTemplate is null || PreviewPng is null)"
                    @onclick="DownloadMap">
                Download map
            </button>
            <button class="oe-btn"
                    disabled="@(GeneratedTemplate is null || PreviewPng is null)"
                    @onclick="DownloadMapWithInstaller">
                Download map w/ installer
            </button>
        </aside>
    </div>

    <footer class="oe-footer">
        Want Steam auto-detect and direct save to <code>map_templates</code>?
        <a href="https://github.com/rannes/Olden-Era---Template-Generator/releases"
           target="_blank" rel="noopener noreferrer">
            Download the Windows app
        </a>.
    </footer>
</div>

@if (ShowLargeMapConfirm)
{
    <div class="oe-modal-overlay" @onclick="CancelLargeMapConfirm">
        <div class="oe-modal" @onclick:stopPropagation="true">
            <h2>Large map — please confirm</h2>
            <p>
                This may take several minutes for large maps.
                The browser tab will be unresponsive during generation.
                Continue?
            </p>
            <div class="oe-modal-actions">
                <button class="oe-btn" @onclick="CancelLargeMapConfirm">Cancel</button>
                <button class="oe-btn primary" @onclick="ConfirmLargeMapAndGenerate">Generate</button>
            </div>
        </div>
    </div>
}

@if (IsGenerating)
{
    <div class="oe-modal-overlay">
        <div class="oe-modal oe-modal-spinner">
            <div class="oe-spinner" aria-hidden="true"></div>
            <p>Generating template…</p>
            <p class="oe-hint">The tab may freeze briefly. Please wait.</p>
        </div>
    </div>
}

@code {
    private static readonly System.Text.Json.JsonSerializerOptions JsonOptions = new()
    {
        WriteIndented = true,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull,
    };

    private const int LargeMapSizeThreshold = 240;
    private const int LargeMapZoneThreshold = 16;

    private enum Section { Map, Heroes, Topology, Zones, WinConditions, Experimental }
    private Section ActiveSection { get; set; } = Section.Map;

    private GeneratorSettings Settings { get; set; } = new();
    private bool AdvancedMode { get; set; }
    private bool ExperimentalMapSizes { get; set; }
    private bool ExperimentalEnabled { get; set; }

    private OldenEra.Generator.Models.Unfrozen.RmgTemplate? GeneratedTemplate;
    private byte[]? PreviewPng;

    private string ValidationMessage = "";
    private bool IsValid = true;

    private string VersionLabel = "v1.0";
    private Version? CurrentVersion;
    private Version? UpdateAvailable;

    private bool ShowLargeMapConfirm;
    private bool IsGenerating;

    // Debounced localStorage save state.
    private System.Threading.CancellationTokenSource? _saveCts;
    private bool _hasLoadedFromStorage;

    protected override async Task OnInitializedAsync()
    {
        CurrentVersion = typeof(Home).Assembly.GetName().Version;
        if (CurrentVersion is not null)
            VersionLabel = FormatVersion(CurrentVersion);

        SettingsFile? sourceOfTruth = null;

        // 1. Share link in fragment wins.
        string hash = await Js.InvokeAsync<string>("oeShare.getHash");
        if (hash.StartsWith("s=", StringComparison.Ordinal))
        {
            var fromUrl = SettingsShareCodec.TryDecode(hash[2..], out _);
            if (fromUrl is not null)
            {
                sourceOfTruth = fromUrl;
            }
            else
            {
                ShareToast = "Share link was invalid — loading your saved settings instead.";
            }
        }

        // 2. Otherwise localStorage.
        sourceOfTruth ??= await SettingsStore.LoadAsync();

        if (sourceOfTruth is not null)
        {
            var (mapped, advanced, experimental, expEnabled) = SettingsMapper.FromFile(sourceOfTruth);
            Settings = mapped;
            AdvancedMode = advanced;
            ExperimentalMapSizes = experimental;
            ExperimentalEnabled = expEnabled;
        }
        _hasLoadedFromStorage = true;

        Validate();
        _ = CheckForUpdatesAsync();
    }

    private async Task CheckForUpdatesAsync()
    {
        var newer = await UpdateChecker.GetNewerVersionAsync(CurrentVersion);
        if (newer is not null)
        {
            UpdateAvailable = newer;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void DismissUpdateBanner()
    {
        UpdateAvailable = null;
    }

    private static string FormatVersion(Version v)
        => v.Build > 0 ? $"v{v.Major}.{v.Minor}.{v.Build}" : $"v{v.Major}.{v.Minor}";

    private void OnExperimentalEnabledChanged(ChangeEventArgs e)
    {
        ExperimentalEnabled = (bool)e.Value!;
        // If user just disabled experimental mode and was sitting on that
        // section, bounce them back to Map so the empty content area doesn't
        // linger. Their experimental settings stay intact in memory.
        if (!ExperimentalEnabled && ActiveSection == Section.Experimental)
            ActiveSection = Section.Map;
        OnChanged();
    }

    private void OnExperimentalToggled(bool value)
    {
        ExperimentalMapSizes = value;
        if (!ExperimentalMapSizes && KnownValues.IsExperimentalMapSize(Settings.MapSize))
            Settings.MapSize = KnownValues.MaxOfficialMapSize;
        OnChanged();
    }

    private void OnAdvancedModeChanged(bool advanced)
    {
        AdvancedMode = advanced;
        Settings.ZoneCfg.Advanced.Enabled = advanced;
        OnChanged();
    }

    private void OnAdvancedHeaderToggled(ChangeEventArgs e)
    {
        bool advanced = (bool)e.Value!;
        AdvancedMode = advanced;
        Settings.ZoneCfg.Advanced.Enabled = advanced;

        // Seed per-tier sliders from the simple-mode values when transitioning
        // off → on, so the Advanced panel doesn't show all-zero counts.
        if (advanced)
        {
            int total = Settings.ZoneCfg.Advanced.NeutralLowNoCastleCount
                      + Settings.ZoneCfg.Advanced.NeutralLowCastleCount
                      + Settings.ZoneCfg.Advanced.NeutralMediumNoCastleCount
                      + Settings.ZoneCfg.Advanced.NeutralMediumCastleCount
                      + Settings.ZoneCfg.Advanced.NeutralHighNoCastleCount
                      + Settings.ZoneCfg.Advanced.NeutralHighCastleCount;
            if (total == 0 && Settings.ZoneCfg.NeutralZoneCount > 0)
            {
                if (Settings.ZoneCfg.NeutralZoneCastles > 0)
                    Settings.ZoneCfg.Advanced.NeutralMediumCastleCount = Settings.ZoneCfg.NeutralZoneCount;
                else
                    Settings.ZoneCfg.Advanced.NeutralMediumNoCastleCount = Settings.ZoneCfg.NeutralZoneCount;
            }
        }
        OnChanged();
    }

    private void OnChanged()
    {
        Validate();
        SchedulePersist();
        StateHasChanged();
    }

    /// <summary>
    /// Debounce localStorage writes so we don't hammer it on every keystroke.
    /// Each change resets a 500 ms timer; only the last change in a burst is saved.
    /// </summary>
    private void SchedulePersist()
    {
        if (!_hasLoadedFromStorage) return;
        _saveCts?.Cancel();
        _saveCts?.Dispose();
        var cts = new System.Threading.CancellationTokenSource();
        _saveCts = cts;
        _ = PersistAfterDelayAsync(cts.Token);
    }

    private async Task PersistAfterDelayAsync(System.Threading.CancellationToken ct)
    {
        try
        {
            await Task.Delay(500, ct);
        }
        catch (TaskCanceledException) { return; }

        if (ct.IsCancellationRequested) return;
        var snapshot = SettingsMapper.ToFile(Settings, AdvancedMode, ExperimentalMapSizes, ExperimentalEnabled);
        await SettingsStore.SaveAsync(snapshot);
    }

    private int TotalNeutralZones()
    {
        // Mirror the validator's view: when AdvancedMode is on, the bucket counts
        // override the simple slider regardless of what's persisted on Settings.
        Settings.ZoneCfg.Advanced.Enabled = AdvancedMode;
        return SettingsValidator.TotalNeutralZones(Settings);
    }

    /// <summary>Delegates to the shared <see cref="SettingsValidator"/>.</summary>
    private void Validate()
    {
        Settings.ZoneCfg.Advanced.Enabled = AdvancedMode;
        var result = SettingsValidator.Validate(Settings);
        if (!result.IsValid)
        {
            IsValid = false;
            ValidationMessage = result.Blockers[0];
            return;
        }
        IsValid = true;
        ValidationMessage = result.Warnings.Count > 0 ? string.Join("\n\n", result.Warnings) : "";
    }

    // -- Generate flow -----------------------------------------------------

    private bool IsLargeMap()
    {
        if (Settings.MapSize >= LargeMapSizeThreshold) return true;
        int total = Settings.PlayerCount + TotalNeutralZones();
        return total >= LargeMapZoneThreshold;
    }

    private async Task OnGenerateClick()
    {
        if (!IsValid || IsGenerating) return;
        if (IsLargeMap())
        {
            ShowLargeMapConfirm = true;
            return;
        }
        await RunGenerationAsync();
    }

    private void CancelLargeMapConfirm()
    {
        ShowLargeMapConfirm = false;
    }

    private async Task ConfirmLargeMapAndGenerate()
    {
        ShowLargeMapConfirm = false;
        await RunGenerationAsync();
    }

    private async Task RunGenerationAsync()
    {
        IsGenerating = true;
        StateHasChanged();
        // Yield so the spinner overlay actually paints before we hand the
        // WASM main thread over to the (synchronous) generator.
        await Task.Yield();
        await Task.Delay(1);

        try
        {
            // Make sure advanced flag in payload reflects UI mode.
            Settings.ZoneCfg.Advanced.Enabled = AdvancedMode;
            if (!AdvancedMode)
            {
                Settings.MinNeutralZonesBetweenPlayers = 0;
                Settings.ZoneCfg.Advanced.PlayerZoneSize = 1.0;
                Settings.ZoneCfg.Advanced.NeutralZoneSize = 1.0;
                Settings.ZoneCfg.Advanced.GuardRandomization = 0.05;
            }

            GeneratedTemplate = TemplateGenerator.Generate(Settings);
            PreviewPng = TemplatePreviewRenderer.RenderPng(GeneratedTemplate, Settings.Topology);
        }
        finally
        {
            IsGenerating = false;
            StateHasChanged();
        }
    }

    // -- Import / Export ---------------------------------------------------

    private async Task SaveSettingsClick()
    {
        var snapshot = SettingsMapper.ToFile(Settings, AdvancedMode, ExperimentalMapSizes, ExperimentalEnabled);
        byte[] bytes = System.Text.Json.JsonSerializer.SerializeToUtf8Bytes(snapshot, JsonOptions);
        string name = string.IsNullOrWhiteSpace(Settings.TemplateName) ? "My Settings" : Settings.TemplateName.Trim();
        await Downloader.DownloadAsync($"{name}.oetgs", "application/json", bytes);
    }

    private async Task OpenSettingsClick()
    {
        // Trigger the hidden InputFile via JS — Blazor doesn't expose a Click
        // method, so we forward a click to the underlying <input type=file>.
        await JsClickAsync("oeOpenSettingsFile");
    }

    [Inject] private IJSRuntime Js { get; set; } = default!;

    private async Task JsClickAsync(string elementId)
    {
        // No need for a custom JS file — eval is fine for a one-liner click.
        await Js.InvokeVoidAsync("eval", $"document.getElementById('{elementId}')?.click()");
    }

    private async Task OnSettingsFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        try
        {
            // Cap at 1 MB — settings files are tiny.
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024);
            using var reader = new StreamReader(stream);
            string json = await reader.ReadToEndAsync();
            var s = System.Text.Json.JsonSerializer.Deserialize<SettingsFile>(json);
            if (s is null) return;

            var (mapped, advanced, experimental, expEnabled) = SettingsMapper.FromFile(s);
            Settings = mapped;
            AdvancedMode = advanced;
            ExperimentalMapSizes = experimental;
            ExperimentalEnabled = expEnabled;
            Validate();
            // Persist the freshly imported settings so they survive a reload.
            await SettingsStore.SaveAsync(SettingsMapper.ToFile(Settings, AdvancedMode, ExperimentalMapSizes, ExperimentalEnabled));
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ValidationMessage = $"Failed to open settings: {ex.Message}";
            IsValid = false;
            StateHasChanged();
        }
    }

    private async Task DownloadMap()
    {
        if (GeneratedTemplate is null || PreviewPng is null) return;
        string name = ResolveTemplateName();
        byte[] json = System.Text.Json.JsonSerializer.SerializeToUtf8Bytes(GeneratedTemplate, JsonOptions);
        byte[] zip = InstallerPackager.BuildPlainZip(name, json, PreviewPng);
        await Downloader.DownloadAsync($"{name}.zip", "application/zip", zip);
    }

    private async Task DownloadMapWithInstaller()
    {
        if (GeneratedTemplate is null || PreviewPng is null) return;
        string name = ResolveTemplateName();
        byte[] json = System.Text.Json.JsonSerializer.SerializeToUtf8Bytes(GeneratedTemplate, JsonOptions);
        byte[] zip = InstallerPackager.BuildInstallerZip(name, json, PreviewPng);
        await Downloader.DownloadAsync($"{name}-installer.zip", "application/zip", zip);
    }

    private string ResolveTemplateName() =>
        string.IsNullOrWhiteSpace(Settings.TemplateName) ? "Custom Template" : Settings.TemplateName.Trim();

    // -- Share link --------------------------------------------------------

    private string ShareToast = "";
    private System.Threading.CancellationTokenSource? _toastCts;

    private async Task ShareSettingsClick()
    {
        var snapshot = SettingsMapper.ToFile(Settings, AdvancedMode, ExperimentalMapSizes, ExperimentalEnabled);
        string encoded = SettingsShareCodec.Encode(snapshot);
        if (encoded.Length > SettingsShareCodec.MaxEncodedLength)
        {
            await FlashToast("Settings too large to share via URL.");
            return;
        }
        string url = await Js.InvokeAsync<string>("oeShare.buildShareUrl", encoded);
        bool copied = await Js.InvokeAsync<bool>("oeShare.copy", url);
        await FlashToast(copied ? "Link copied to clipboard." : "Couldn't copy — select the URL bar to copy manually.");
        await Js.InvokeVoidAsync("oeShare.setHash", "s=" + encoded);
    }

    private async Task FlashToast(string msg)
    {
        _toastCts?.Cancel();
        _toastCts?.Dispose();
        var cts = new System.Threading.CancellationTokenSource();
        _toastCts = cts;
        ShareToast = msg;
        StateHasChanged();
        try { await Task.Delay(2500, cts.Token); } catch (TaskCanceledException) { return; }
        if (cts.IsCancellationRequested) return;
        ShareToast = "";
        StateHasChanged();
    }

    public void Dispose()
    {
        _saveCts?.Cancel();
        _saveCts?.Dispose();
        _toastCts?.Cancel();
        _toastCts?.Dispose();
    }
}
