<Window x:Class="Olden_Era___Template_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Olden_Era___Template_Editor.Views"
        mc:Ignorable="d"
        Title="Olden Era - Simple Template Generator"
        Height="800" Width="1050"
        MinHeight="800" MinWidth="1050"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Background="#1A1510"
        FontFamily="Segoe UI, Arial, sans-serif">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.New}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Open}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{x:Static ApplicationCommands.SaveAs}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"    Executed="BtnNew_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"   Executed="BtnOpen_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"   Executed="BtnSave_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.SaveAs}" Executed="BtnSaveAs_Click"/>
    </Window.CommandBindings>

    <!-- Hidden combo boxes required by code-behind -->
    <Window.Resources>
        <Style x:Key="RowSpacer" TargetType="RowDefinition">
            <Setter Property="Height" Value="8"/>
        </Style>
    </Window.Resources>

    <!-- Outer border gives the window its themed frame -->
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>    <!-- custom title bar -->
                <RowDefinition Height="1"/>     <!-- gold divider -->
                <RowDefinition Height="*"/>     <!-- page content -->
            </Grid.RowDefinitions>

            <!-- ════════ CUSTOM TITLE BAR ══════════════════════════════ -->
            <Grid Grid.Row="0" Background="#0F0D09">
                <!-- Icon + title (drag region) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Image Source="pack://application:,,,/favicon.ico" Width="18" Height="18"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="TxtWindowTitle"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Caption buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <Button Content="🗕" Style="{StaticResource TitleBarButton}"
                            ToolTip="Minimize" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="🗖" Style="{StaticResource TitleBarButton}"
                            ToolTip="Maximize" Click="BtnMaximize_Click"/>
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                            ToolTip="Close" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Gold divider line under title bar -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- ════════ PAGE CONTENT ═══════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="14,8,14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- toolbar -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>  <!-- WIP warning -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>  <!-- thin divider -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>     <!-- main content -->
                </Grid.RowDefinitions>

        <!-- ════════ TOOLBAR ══════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="📄  Reset Settings"      Margin="0,0,6,0" Click="BtnNew_Click"    Style="{StaticResource ToolbarButton}" ToolTip="New (Ctrl+N)"/>
            <Button Content="📂  Open Settings"      Margin="0,0,6,0" Click="BtnOpen_Click"   Style="{StaticResource ToolbarButton}" ToolTip="Open (Ctrl+O)"/>
            <Button Content="💾  Save Settings"      Margin="0,0,6,0" Click="BtnSave_Click"   Style="{StaticResource ToolbarButton}" ToolTip="Save (Ctrl+S)"/>
            <Button Content="💾  Save Settings As"   Margin="0,0,0,0" Click="BtnSaveAs_Click" Style="{StaticResource ToolbarButton}" ToolTip="Save As (Ctrl+Shift+S)"/>
                </StackPanel>
                <!-- ════════ WIP WARNING ═══════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushWarnBg}"
                BorderBrush="{StaticResource BrushWarnBorder}"
                BorderThickness="1" CornerRadius="3"
                Padding="10,7">
            <StackPanel Orientation="Vertical">
                <TextBlock x:Name="TxtWipWarning"
                           Foreground="{StaticResource BrushWarnText}"
                           FontSize="11" TextWrapping="Wrap"/>
                <TextBlock Foreground="{StaticResource BrushWarnText}"
                           FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0">
                    Prefer the browser?
                    <Hyperlink x:Name="LinkWebVersion"
                               NavigateUri="https://rannes.github.io/Olden-Era---Template-Generator/"
                               RequestNavigate="LinkWebVersion_RequestNavigate">Try the web version</Hyperlink>.
                </TextBlock>
            </StackPanel>
        </Border>
        <!-- ════════ HEADER ════════════════════════════════════════════ -->
        <Rectangle Grid.Row="4" Height="1" Fill="{StaticResource BrushBorder}" VerticalAlignment="Bottom"/>

        <!-- ════════ MAIN CONTENT — two columns + preview ═════════════════════ -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <TabControl x:Name="MainTabs"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        VerticalContentAlignment="Stretch">
                <TabItem Header="Rules">
                <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 1st row -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- 2nd row -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>     <!-- 3rd row -->
                </Grid.RowDefinitions>

                <!-- TEMPLATE -->
                <views:MapPanel Grid.Row="0" Grid.Column="0" x:Name="PnlMap"/>

                <!-- HEROES -->
                <views:HeroesPanel Grid.Row="0" Grid.Column="2" x:Name="PnlHeroes"/>

                <views:WinConditionsPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" x:Name="PnlGameRules"/>
                    </Grid>
                </TabItem>

            <TabItem Header="Layout &amp; Zones">
            <Grid Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>     <!-- Layout -->
                    <RowDefinition Height="6"/>     
                    <RowDefinition Height="*"/>     <!-- Zone Configuration -->
                </Grid.RowDefinitions>

                <!-- TOPOLOGY -->
                <views:TopologyPanel Grid.Row="0" x:Name="PnlTopology"/>

                <!-- ZONE CONFIGURATION -->
                <views:ZonesPanel Grid.Row="2" x:Name="PnlZones"/>
            </Grid>
        </TabItem>
    </TabControl>

            <!-- ─── PREVIEW COLUMN ───────────────────────────────────── -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- generate button -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- hints / validation -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>      <!-- image -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>   <!-- outdated warning -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- show preview checkbox -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- save button -->
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        x:Name="BtnPreview"
                        Content="⚔  Generate Template"
                        Style="{StaticResource GenerateButton}"
                        Click="BtnPreview_Click"/>

                <TextBlock Grid.Row="2"
                           x:Name="TxtValidation"
                           Foreground="{StaticResource BrushError}"
                           FontSize="12" TextWrapping="Wrap"
                           Visibility="Collapsed"
                           HorizontalAlignment="Stretch" TextAlignment="Center"/>

                <Border Grid.Row="4"
                        BorderThickness="2"
                        CornerRadius="4"
                        BorderBrush="{StaticResource BrushBorder}"
                        Background="#1A1410">
                    <Image x:Name="ImgPreview"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                </Border>

                <CheckBox Grid.Row="8"
                          x:Name="ChkSavePreviewImage"
                          Content="Show preview in-game"
                          IsChecked="True"
                          Visibility="Visible"
                          Foreground="{StaticResource BrushText}"
                          HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="6"
                           x:Name="TxtOutdatedWarning"
                           Foreground="{StaticResource BrushError}"
                           FontSize="12" TextWrapping="Wrap"
                           Visibility="Hidden"
                           HorizontalAlignment="Stretch" TextAlignment="Center"
                           Text="⚠️ Settings have changed — generate a new template before saving to reflect the latest changes."/>

                <Button Grid.Row="10"
                        x:Name="BtnSaveGenerated"
                        Content="💾  Save Template"
                        Style="{StaticResource GenerateButton}"
                        Visibility="Visible"
                        IsEnabled="False"
                        Click="BtnSaveGenerated_Click"/>
            </Grid>

        </Grid>

                    <!-- Hidden combos required by code-behind -->
        <ComboBox Grid.Row="4" x:Name="CmbGameMode" Visibility="Collapsed"/>
        <TextBlock Grid.Row="4" x:Name="TxtAppTitle" Visibility="Collapsed"/>



            </Grid>  <!-- end page content grid -->
        </Grid>      <!-- end outer row grid -->
    </Border>        <!-- end window frame border -->
</Window>
