<Window x:Class="Olden_Era___Template_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Olden Era - Simple Template Generator"
        Height="800" Width="1050"
        MinHeight="800" MinWidth="1050"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Background="#1A1510"
        FontFamily="Segoe UI, Arial, sans-serif">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.New}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Open}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{x:Static ApplicationCommands.SaveAs}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"    Executed="BtnNew_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"   Executed="BtnOpen_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"   Executed="BtnSave_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.SaveAs}" Executed="BtnSaveAs_Click"/>
    </Window.CommandBindings>

    <!-- Hidden combo boxes required by code-behind -->
    <Window.Resources>
        <Style x:Key="RowSpacer" TargetType="RowDefinition">
            <Setter Property="Height" Value="8"/>
        </Style>
    </Window.Resources>

    <!-- Outer border gives the window its themed frame -->
    <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>    <!-- custom title bar -->
                <RowDefinition Height="1"/>     <!-- gold divider -->
                <RowDefinition Height="*"/>     <!-- page content -->
            </Grid.RowDefinitions>

            <!-- ════════ CUSTOM TITLE BAR ══════════════════════════════ -->
            <Grid Grid.Row="0" Background="#0F0D09">
                <!-- Icon + title (drag region) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Image Source="pack://application:,,,/favicon.ico" Width="18" Height="18"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="TxtWindowTitle"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Caption buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <Button Content="🗕" Style="{StaticResource TitleBarButton}"
                            ToolTip="Minimize" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="🗖" Style="{StaticResource TitleBarButton}"
                            ToolTip="Maximize" Click="BtnMaximize_Click"/>
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                            ToolTip="Close" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Gold divider line under title bar -->
            <Rectangle Grid.Row="1" Fill="{StaticResource BrushBorder}"/>

            <!-- ════════ PAGE CONTENT ═══════════════════════════════════ -->
            <Grid Grid.Row="2" Margin="14,8,14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- toolbar -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>  <!-- WIP warning -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>  <!-- thin divider -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>     <!-- main content -->
                </Grid.RowDefinitions>

        <!-- ════════ TOOLBAR ══════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="📄  Reset Settings"      Margin="0,0,6,0" Click="BtnNew_Click"    Style="{StaticResource ToolbarButton}" ToolTip="New (Ctrl+N)"/>
            <Button Content="📂  Open Settings"      Margin="0,0,6,0" Click="BtnOpen_Click"   Style="{StaticResource ToolbarButton}" ToolTip="Open (Ctrl+O)"/>
            <Button Content="💾  Save Settings"      Margin="0,0,6,0" Click="BtnSave_Click"   Style="{StaticResource ToolbarButton}" ToolTip="Save (Ctrl+S)"/>
            <Button Content="💾  Save Settings As"   Margin="0,0,0,0" Click="BtnSaveAs_Click" Style="{StaticResource ToolbarButton}" ToolTip="Save As (Ctrl+Shift+S)"/>
                </StackPanel>
                <!-- ════════ WIP WARNING ═══════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushWarnBg}"
                BorderBrush="{StaticResource BrushWarnBorder}"
                BorderThickness="1" CornerRadius="3"
                Padding="10,7">
            <TextBlock x:Name="TxtWipWarning"
                       Foreground="{StaticResource BrushWarnText}"
                       FontSize="11" TextWrapping="Wrap"/>
        </Border>
        <!-- ════════ HEADER ════════════════════════════════════════════ -->
        <Rectangle Grid.Row="4" Height="1" Fill="{StaticResource BrushBorder}" VerticalAlignment="Bottom"/>

        <!-- ════════ MAIN CONTENT — two columns + preview ═════════════════════ -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <TabControl x:Name="MainTabs"
                        Grid.Column="0"
                        Grid.ColumnSpan="3">
                <TabItem Header="Rules">
                <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 1st row -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- 2nd row -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>  <!-- 3rd row -->
                </Grid.RowDefinitions>

                <!-- TEMPLATE -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="◆  TEMPLATE" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="Template Name"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTemplateName" Text="Custom Template"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="Map Size"/>
                            <ComboBox x:Name="CmbMapSize" Grid.Row="2" Grid.Column="1" SelectionChanged="CmbMapSize_SelectionChanged"/>
                            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
                                <CheckBox x:Name="ChkExperimentalMapSizes"
                                          Content="Experimental large map sizes"
                                          Margin="0,6,0,0"
                                          Visibility="Visible"
                                          Checked="ChkExperimentalMapSizes_Changed"
                                          Unchecked="ChkExperimentalMapSizes_Changed"/>
                                <TextBlock x:Name="TxtExperimentalMapSizeWarning"
                                           Foreground="{StaticResource BrushTextDim}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           Visibility="Collapsed"
                                           Text="Adds 256x256 through 512x512. Official templates top out at 240x240, so larger maps may fail, freeze, or behave unpredictably in game."/>
                            </StackPanel>
                            <DockPanel Grid.Row="6" Grid.Column="0">
                                <Label Content="Players" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtPlayers" Text="2" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="6" Grid.Column="1" x:Name="SldPlayers"
                                    Minimum="2" Maximum="8" Value="2"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- HEROES -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="◆  HEROES" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="185"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Grid.Column="0">
                                <Label Content="Initial hero cap" Padding="5,2" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtHeroMin" Text="4" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldHeroMin"
                                    Minimum="1" Maximum="12" Value="4"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="2" Grid.Column="0">
                                <Label Content="Max hero cap" Padding="5,2" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtHeroMax" Text="8" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SldHeroMax"
                                    Minimum="1" Maximum="12" Value="8"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="4" Grid.Column="0">
                                <Label Content="Increase cap / castle" Padding="5,2" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtHeroIncrement" Text="1" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="4" Grid.Column="1" x:Name="SldHeroIncrement"
                                    Minimum="0" Maximum="10" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                        </Grid>
                        
                    </StackPanel>
                </Border>

                <!-- ADVANCED GAME RULES -->
                <Border Grid.Row="2" x:Name="PnlAdvancedGameRules" Style="{StaticResource SectionBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="◆ GAME RULES" Style="{StaticResource SectionHeader}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="185"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="4" Grid.Column="0" Content="Primary win condition"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="CmbVictory"
                                          SelectionChanged="CmbVictory_SelectionChanged"/>

                                <DockPanel Grid.Row="0" Grid.Column="0">
                                    <Label Content="Faction laws XP" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtFactionLawsExp" Text="100%" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="0" Grid.Column="1" x:Name="SldFactionLawsExp"
                                        Minimum="25" Maximum="200" Value="100"
                                        TickFrequency="25" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                        <DockPanel Grid.Row="2" Grid.Column="0">
                                    <Label Content="Astrology XP" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtAstrologyExp" Text="100%" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="2" Grid.Column="1" x:Name="SldAstrologyExp"
                                        Minimum="25" Maximum="200" Value="100"
                                        TickFrequency="25" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>
                            </Grid>

                            <StackPanel Margin="0,10,0,0">
                                <CheckBox x:Name="ChkLostStartCity"
                                          Content="Lose when starting city is lost"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>
                                <Grid x:Name="PnlLostStartCityDetails" Margin="18,3,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0">
                                        <Label Content="Lost city day" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtLostStartCityDay" Text="3" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,0,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Column="1" x:Name="SldLostStartCityDay"
                                            Minimum="1" Maximum="30" Value="3"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                </Grid>

                                <CheckBox x:Name="ChkLostStartHero"
                                          Content="Lose when starting hero is lost"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>

                                <CheckBox x:Name="ChkCityHold"
                                          Content="Win by holding a neutral city"
                                          Margin="0,6,0,0"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>
                                <Grid x:Name="PnlCityHoldDetails" Margin="18,3,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel Grid.Column="0">
                                        <Label Content="Hold days" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtCityHoldDays" Text="6" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Column="1" x:Name="SldCityHoldDays"
                                            Minimum="1" Maximum="30" Value="6"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                </Grid>

                                <CheckBox x:Name="ChkGladiatorArena"
                                          Content="Use gladiator arena rules"
                                          Margin="0,6,0,0"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed" Visibility="Collapsed"/>
                                <Grid x:Name="PnlGladiatorDetails" Margin="18,3,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Grid.Column="0">
                                        <Label Content="Arena delay" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtGladiatorDelay" Text="30" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="0" Grid.Column="1" x:Name="SldGladiatorDelay"
                                            Minimum="1" Maximum="60" Value="30"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                    <DockPanel Grid.Row="2" Grid.Column="0">
                                        <Label Content="Arena count day" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtGladiatorCountDay" Text="3" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldGladiatorCountDay"
                                            Minimum="1" Maximum="30" Value="3"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                </Grid>

                                <CheckBox x:Name="ChkTournament"
                                          Content="Use tournament rules"
                                          Margin="0,6,0,0"
                                          Checked="WinConditionOption_Changed"
                                          Unchecked="WinConditionOption_Changed"/>
                                <Grid x:Name="PnlTournamentDetails" Margin="18,3,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="167"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Grid.Column="0">
                                        <Label Content="Points to win" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtTournamentPointsToWin" Text="2" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="0" Grid.Column="1" x:Name="SldTournamentPointsToWin"
                                            Minimum="1" Maximum="5" Value="2"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                    <DockPanel Grid.Row="2" Grid.Column="0">
                                        <Label Content="First tournament day" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtTournamentFirstTournamentDay" Text="8" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="2" Grid.Column="1" x:Name="SldTournamentFirstTournamentDay"
                                            Minimum="1" Maximum="30" Value="8"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                    <DockPanel Grid.Row="4" Grid.Column="0">
                                        <Label Content="Announcement Days" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtTournamentAnnouncementLeadDays" Text="3" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="4" Grid.Column="1" x:Name="SldTournamentAnnouncementLeadDays"
                                            Minimum="1" Maximum="10" Value="3"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                    <DockPanel Grid.Row="6" Grid.Column="0">
                                        <Label Content="Days between rounds" Padding="5,2" DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="TxtTournamentInterval" Text="7" DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                    </DockPanel>
                                    <Slider Grid.Row="6" Grid.Column="1" x:Name="SldTournamentInterval"
                                            Minimum="1" Maximum="30" Value="7"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            ValueChanged="Slider_ValueChanged"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                   </DockPanel>
                                </Border>
                    </Grid>
                </TabItem>

            <TabItem Header="Layout &amp; Zones">
            <Grid Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>     <!-- Layout -->
                    <RowDefinition Height="6"/>     
                    <RowDefinition Height="*"/>     <!-- Zone Configuration -->
                </Grid.RowDefinitions>

                <!-- TOPOLOGY -->
                <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="◆  LAYOUT" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Map Layout"/>
                            <ComboBox Grid.Column="1" x:Name="CmbTopology"
                                      SelectionChanged="CmbTopology_SelectionChanged"/>
                        </Grid>
                        <TextBlock x:Name="TxtTopologyDesc"
                                   Foreground="{StaticResource BrushTextDim}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ZONE CONFIGURATION -->
                <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
                    <DockPanel>
                        <DockPanel LastChildFill="False" DockPanel.Dock="Top">
                            <TextBlock Text="◆  ZONE CONFIGURATION" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                            <CheckBox x:Name="ChkAdvancedZoneSettings" Content="Advanced settings"
                                      DockPanel.Dock="Right"
                                      Margin="15,0,0,8"
                                      VerticalAlignment="Center"
                                      FontSize="11"
                                      Checked="BtnAdvancedZoneSettings_Click"
                                      Unchecked="BtnAdvancedZoneSettings_Click"/>
                        </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Grid.Column="0" x:Name="PnlSimpleNeutralCountLabel">
                                <Label Content="Additional Neutral Zones" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtNeutral" Text="0" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldNeutral"
                                    Minimum="0" Maximum="30" Value="0"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="2" Grid.Column="0">
                                <Label Content="Castles / Player Zone" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtPlayerCastles" Text="1" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SldPlayerCastles"
                                    Minimum="1" Maximum="4" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="4" Grid.Column="0">
                                <Label Content="Castles / Neutral Zone" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtNeutralCastles" Text="1" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="4" Grid.Column="1" x:Name="SldNeutralCastles"
                                    Minimum="0" Maximum="4" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="6" Grid.Column="0">
                                <Label Content="Resource spawn rate" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtResourceDensity" Text="100%" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="6" Grid.Column="1" x:Name="SldResourceDensity"
                                    Minimum="20" Maximum="400" Value="100"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="8" Grid.Column="0">
                                <Label Content="Structure spawn rate" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtStructureDensity" Text="100%" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="8" Grid.Column="1" x:Name="SldStructureDensity"
                                    Minimum="20" Maximum="200" Value="100"
                                    TickFrequency="10" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="10" Grid.Column="0">
                                <Label Content="Zone neutral strength" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtNeutralStackStrength" Text="100%" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="10" Grid.Column="1" x:Name="SldNeutralStackStrength"
                                    Minimum="25" Maximum="300" Value="100"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>

                            <DockPanel Grid.Row="12" Grid.Column="0">
                                <Label Content="Border/portal strength" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TxtBorderGuardStrength" Text="100%" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Margin="0,0,10,0" Style="{StaticResource ValueText}"/>
                            </DockPanel>
                            <Slider Grid.Row="12" Grid.Column="1" x:Name="SldBorderGuardStrength"
                                    Minimum="25" Maximum="300" Value="100"
                                    TickFrequency="5" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                        </Grid>
                        <StackPanel x:Name="PnlPlayerCastleFactionOption"
                                    Visibility="Collapsed"
                                    Margin="0,10,0,0">
                            <CheckBox x:Name="ChkMatchPlayerCastleFactions"
                                      Content="Use one faction for all castles in each player zone"
                                      Checked="ChkOption_Changed"
                                      Unchecked="ChkOption_Changed"/>
                        </StackPanel>
                        <StackPanel x:Name="PnlAdvancedZoneSizes"
                                    Visibility="Collapsed"
                                    Margin="0,12,0,0">
                            <TextBlock Text="Advanced zone tuning [EXPERIMENTAL]"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Foreground="{StaticResource BrushTextDim}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Text="Relative region weights and guard variance used by the game layout."/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Grid.Column="0">
                                    <Label Content="Player zone size" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtPlayerZoneSize" Text="1.00x" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="0" Grid.Column="1" x:Name="SldPlayerZoneSize"
                                        Minimum="0.5" Maximum="2" Value="1"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="2" Grid.Column="0">
                                    <Label Content="Neutral zone size" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtNeutralZoneSize" Text="1.00x" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="2" Grid.Column="1" x:Name="SldNeutralZoneSize"
                                        Minimum="0.5" Maximum="2" Value="1"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="4" Grid.Column="0">
                                    <Label Content="Guard strength randomization" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtGuardRandomization" Text="5%" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="4" Grid.Column="1" x:Name="SldGuardRandomization"
                                        Minimum="0" Maximum="50" Value="5"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="PnlAdvancedNeutralZones"
                                    Visibility="Collapsed"
                                    Margin="0,12,0,0">
                            <TextBlock Text="Advanced neutral zones"
                                       Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Foreground="{StaticResource BrushTextDim}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Text="With-castle neutral zones use the Castles / Neutral Zone value. Each advanced slider is capped at 8; total zones are capped at 32 in advanced mode."/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="4"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Grid.Column="0">
                                    <Label Content="Low neutral, no castle" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtNeutralLowNoCastle" Text="0" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="0" Grid.Column="1" x:Name="SldNeutralLowNoCastle"
                                        Minimum="0" Maximum="30" Value="0"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="2" Grid.Column="0">
                                    <Label Content="Low neutral, castle" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtNeutralLowCastle" Text="0" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="2" Grid.Column="1" x:Name="SldNeutralLowCastle"
                                        Minimum="0" Maximum="30" Value="0"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="4" Grid.Column="0">
                                    <Label Content="Medium neutral, no castle" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtNeutralMediumNoCastle" Text="0" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="4" Grid.Column="1" x:Name="SldNeutralMediumNoCastle"
                                        Minimum="0" Maximum="30" Value="0"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="6" Grid.Column="0">
                                    <Label Content="Medium neutral, castle" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtNeutralMediumCastle" Text="0" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="6" Grid.Column="1" x:Name="SldNeutralMediumCastle"
                                        Minimum="0" Maximum="30" Value="0"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="8" Grid.Column="0">
                                    <Label Content="High neutral, no castle" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtNeutralHighNoCastle" Text="0" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="8" Grid.Column="1" x:Name="SldNeutralHighNoCastle"
                                        Minimum="0" Maximum="30" Value="0"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>

                                <DockPanel Grid.Row="10" Grid.Column="0">
                                    <Label Content="High neutral, castle" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtNeutralHighCastle" Text="0" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Row="10" Grid.Column="1" x:Name="SldNeutralHighCastle"
                                        Minimum="0" Maximum="30" Value="0"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="PnlAdvancedSeparation"
                                    Visibility="Collapsed"
                                    Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0">
                                    <Label Content="Min neutrals between players" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="TxtMinNeutralBetweenPlayers" Text="0" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Column="1" x:Name="SldMinNeutralBetweenPlayers"
                                        Minimum="0" Maximum="8" Value="0"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="Slider_ValueChanged"/>
                            </Grid>
                            <TextBlock Foreground="{StaticResource BrushTextDim}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       Text="Honored only when the selected layout, neutral zone total, and portal settings can support it; otherwise generation uses the normal connection layout."/>
                        </StackPanel>
                                <CheckBox x:Name="ChkGenerateRoads" Content="Generate roads" IsChecked="True"
          Checked="ChkOption_Changed" Unchecked="ChkOption_Changed" Margin="0,10,0,0"/>
                                <TextBlock x:Name="TxtRoadsHint"
            Visibility="Collapsed"
            Foreground="{StaticResource BrushTextDim}"
            FontSize="13" TextWrapping="Wrap"
            Margin="18,3,0,0"
            Text="Note: Roads are only generated within zones that have at least one castle. Neutral zones with 0 castles will not have roads, even if this option is enabled."/>
                                <CheckBox x:Name="ChkSpawnFootholds" Content="Spawn remote footholds" IsChecked="True" Margin="0,6,0,0"/>
                        <CheckBox x:Name="ChkRandomPortals"  Content="Always spawn portals"          Margin="0,6,0,0"
                                  Checked="ChkRandomPortals_Changed" Unchecked="ChkRandomPortals_Changed"/>
                        <StackPanel x:Name="PnlMaxPortals" Visibility="Collapsed" Margin="25,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="205"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0">
                                    <Label Content="Max portal connections" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="LblMaxPortals" Text="32" DockPanel.Dock="Right"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="0,0,4,0" Style="{StaticResource ValueText}"/>
                                </DockPanel>
                                <Slider Grid.Column="1" x:Name="SldMaxPortals" Minimum="1" Maximum="32" Value="32"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="SldMaxPortals_ValueChanged"/>
                            </Grid>
                        </StackPanel>
                        <CheckBox x:Name="ChkBalancedZonePlacement"
                                  Content="Balance zone placement [RECOMMENDED]"
                                  IsChecked="True"
                                  Margin="0,6,0,0"
                                  Checked="ChkOption_Changed" Unchecked="ChkOption_Changed"/>
                        <TextBlock x:Name="TxtBalancedZonePlacementDesc"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource BrushTextDim}"
                                   FontSize="13" TextWrapping="Wrap"
                                   Margin="25,3,0,0"
                                   Text="Spreads players and neutral zone tiers more evenly across structured layouts. Random layout uses balanced seed positions before building borders. We recommend to keep this setting enabled."/>
                        <CheckBox x:Name="ChkNoDirectPlayerConn"
                                  Content="Connect via neutral zones only [EXPERIMENTAL]"
                                  Margin="0,6,0,0"
                                  Visibility="Collapsed"
                                  Checked="ChkOption_Changed" Unchecked="ChkOption_Changed"/>
                        <TextBlock x:Name="TxtIsolateDesc"
                                   Visibility="Collapsed"
                                   Foreground="{StaticResource BrushTextDim}"
                                   FontSize="13" TextWrapping="Wrap"
                                   Margin="25,3,0,0"
                                   Text="The game tries to connect player zones to neutral zones only. If no neutral zone borders a player zone, it will fall back to connecting directly to another player zone."/>
                        </StackPanel>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>

            <!-- ─── PREVIEW COLUMN ───────────────────────────────────── -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- generate button -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- hints / validation -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>      <!-- image -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>   <!-- outdated warning -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- show preview checkbox -->
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>   <!-- save button -->
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        x:Name="BtnPreview"
                        Content="⚔  Generate Template"
                        Style="{StaticResource GenerateButton}"
                        Click="BtnPreview_Click"/>

                <TextBlock Grid.Row="2"
                           x:Name="TxtValidation"
                           Foreground="{StaticResource BrushError}"
                           FontSize="12" TextWrapping="Wrap"
                           Visibility="Collapsed"
                           HorizontalAlignment="Stretch" TextAlignment="Center"/>

                <Border Grid.Row="4"
                        BorderThickness="2"
                        CornerRadius="4"
                        BorderBrush="{StaticResource BrushBorder}"
                        Background="#1A1410">
                    <Image x:Name="ImgPreview"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                </Border>

                <CheckBox Grid.Row="8"
                          x:Name="ChkSavePreviewImage"
                          Content="Show preview in-game"
                          IsChecked="True"
                          Visibility="Visible"
                          Foreground="{StaticResource BrushText}"
                          HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="6"
                           x:Name="TxtOutdatedWarning"
                           Foreground="{StaticResource BrushError}"
                           FontSize="12" TextWrapping="Wrap"
                           Visibility="Hidden"
                           HorizontalAlignment="Stretch" TextAlignment="Center"
                           Text="⚠️ Settings have changed — generate a new template before saving to reflect the latest changes."/>

                <Button Grid.Row="10"
                        x:Name="BtnSaveGenerated"
                        Content="💾  Save Template"
                        Style="{StaticResource GenerateButton}"
                        Visibility="Visible"
                        IsEnabled="False"
                        Click="BtnSaveGenerated_Click"/>
            </Grid>

        </Grid>

                    <!-- Hidden combos required by code-behind -->
        <ComboBox Grid.Row="4" x:Name="CmbGameMode" Visibility="Collapsed"/>
        <TextBlock Grid.Row="4" x:Name="TxtAppTitle" Visibility="Collapsed"/>



            </Grid>  <!-- end page content grid -->
        </Grid>      <!-- end outer row grid -->
    </Border>        <!-- end window frame border -->
</Window>
