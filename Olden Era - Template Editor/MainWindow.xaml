<Window x:Class="Olden_Era___Template_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Olden Era - Simple Template Generator"
        Height="560" Width="960"
        MinHeight="500" MinWidth="800"
        ResizeMode="CanMinimize"
        Background="#1A1510"
        FontFamily="Segoe UI, Arial, sans-serif">

    <!-- Hidden combo boxes required by code-behind -->
    <Window.Resources>
        <Style x:Key="RowSpacer" TargetType="RowDefinition">
            <Setter Property="Height" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,8,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- thin divider -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>     <!-- main content -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- validation -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>  <!-- WIP warning -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>  <!-- generate button -->
        </Grid.RowDefinitions>

        <!-- ════════ HEADER ════════════════════════════════════════════ -->
        <Rectangle Grid.Row="0" Height="1" Fill="{StaticResource BrushBorder}" VerticalAlignment="Bottom"/>

        <!-- ════════ MAIN CONTENT — two columns ════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT COLUMN ─────────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- template -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>     <!-- zone config -->
                </Grid.RowDefinitions>

                <!-- TEMPLATE -->
                <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="◆  TEMPLATE" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Label Grid.Row="0" Grid.Column="0" Content="Template Name"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtTemplateName" Text="Custom Template"/>
                            <Label Grid.Row="2" Grid.Column="0" Content="Map Size"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CmbMapSize"
                                      SelectionChanged="CmbMapSize_SelectionChanged"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ZONE CONFIGURATION -->
                <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="◆  ZONE CONFIGURATION" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Players"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldPlayers"
                                    Minimum="2" Maximum="8" Value="2"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="TxtPlayers" Text="2"
                                       Style="{StaticResource ValueText}"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Additional Neutral Zones"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SldNeutral"
                                    Minimum="0" Maximum="8" Value="0"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="TxtNeutral" Text="0"
                                       Style="{StaticResource ValueText}"/>

                            <Label Grid.Row="4" Grid.Column="0" Content="Castles / Player Zone"/>
                            <Slider Grid.Row="4" Grid.Column="1" x:Name="SldPlayerCastles"
                                    Minimum="1" Maximum="4" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="TxtPlayerCastles" Text="1"
                                       Style="{StaticResource ValueText}"/>

                            <Label Grid.Row="6" Grid.Column="0" Content="Castles / Neutral Zone"/>
                            <Slider Grid.Row="6" Grid.Column="1" x:Name="SldNeutralCastles"
                                    Minimum="1" Maximum="4" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <TextBlock Grid.Row="6" Grid.Column="2" x:Name="TxtNeutralCastles" Text="1"
                                       Style="{StaticResource ValueText}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ─── RIGHT COLUMN ─────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- options -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>  <!-- topology -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>     <!-- heroes -->
                </Grid.RowDefinitions>

                <!-- OPTIONS -->
                <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="◆  OPTIONS" Style="{StaticResource SectionHeader}"/>
                        <CheckBox x:Name="ChkNoDirectPlayerConn"
                                  Content="Isolate player zones (connect via neutrals only)"
                                  Checked="ChkOption_Changed" Unchecked="ChkOption_Changed"/>
                        <CheckBox x:Name="ChkRandomPortals"  Content="Spawn portals"         Margin="0,6,0,0"/>
                        <CheckBox x:Name="ChkSpawnFootholds" Content="Spawn remote footholds" IsChecked="True" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- TOPOLOGY -->
                <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="◆  TOPOLOGY" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Grid.Column="0" Content="Map Topology"/>
                            <ComboBox Grid.Column="1" x:Name="CmbTopology"
                                      SelectionChanged="CmbTopology_SelectionChanged"/>
                        </Grid>
                        <TextBlock x:Name="TxtTopologyDesc"
                                   Foreground="{StaticResource BrushTextDim}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- HEROES -->
                <Border Grid.Row="4" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="◆  HEROES" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Min Heroes"/>
                            <Slider Grid.Row="0" Grid.Column="1" x:Name="SldHeroMin"
                                    Minimum="1" Maximum="10" Value="10"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" x:Name="TxtHeroMin" Text="10"
                                       Style="{StaticResource ValueText}"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Max Heroes"/>
                            <Slider Grid.Row="2" Grid.Column="1" x:Name="SldHeroMax"
                                    Minimum="1" Maximum="50" Value="10"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" x:Name="TxtHeroMax" Text="10"
                                       Style="{StaticResource ValueText}"/>

                            <Label Grid.Row="4" Grid.Column="0" Content="Increase heroes / castle"/>
                            <Slider Grid.Row="4" Grid.Column="1" x:Name="SldHeroIncrement"
                                    Minimum="0" Maximum="10" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                            <TextBlock Grid.Row="4" Grid.Column="2" x:Name="TxtHeroIncrement" Text="1"
                                       Style="{StaticResource ValueText}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Hidden combos required by code-behind -->
        <ComboBox Grid.Row="0" x:Name="CmbGameMode" Visibility="Collapsed"/>
        <ComboBox Grid.Row="0" x:Name="CmbVictory"  Visibility="Collapsed"/>
        <TextBlock Grid.Row="0" x:Name="TxtAppTitle" Visibility="Collapsed"/>

        <!-- ════════ VALIDATION ════════════════════════════════════════ -->
        <TextBlock Grid.Row="4"
                   x:Name="TxtValidation"
                   Foreground="{StaticResource BrushError}"
                   FontSize="12" TextWrapping="Wrap"
                   HorizontalAlignment="Stretch" TextAlignment="Center"/>

        <!-- ════════ WIP WARNING ═══════════════════════════════════════ -->
        <Border Grid.Row="6"
                Background="{StaticResource BrushWarnBg}"
                BorderBrush="{StaticResource BrushWarnBorder}"
                BorderThickness="1" CornerRadius="3"
                Padding="10,7">
            <TextBlock x:Name="TxtWipWarning"
                       Foreground="{StaticResource BrushWarnText}"
                       FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- ════════ GENERATE BUTTON ═══════════════════════════════════ -->
        <Button Grid.Row="8"
                x:Name="BtnGenerate"
                Content="⚔  Generate &amp; Save…"
                Style="{StaticResource GenerateButton}"
                Click="BtnGenerate_Click"/>

    </Grid>
</Window>
