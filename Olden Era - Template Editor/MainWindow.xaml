<Window x:Class="Olden_Era___Template_Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Olden_Era___Template_Editor.Views"
        mc:Ignorable="d"
        Title="Olden Era - Simple Template Generator"
        Height="800" Width="1050"
        MinHeight="800" MinWidth="1050"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="Window_StateChanged"
        Background="{StaticResource OeBgBrush}"
        Foreground="{StaticResource OeTextBrush}"
        FontFamily="{StaticResource OeFont}"
        FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,1"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.New}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Open}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{x:Static ApplicationCommands.SaveAs}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}"    Executed="BtnNew_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}"   Executed="BtnOpen_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"   Executed="BtnSave_Click"/>
        <CommandBinding Command="{x:Static ApplicationCommands.SaveAs}" Executed="BtnSaveAs_Click"/>
    </Window.CommandBindings>

    <!-- Hidden combo boxes required by code-behind -->
    <Window.Resources>
        <Style x:Key="RowSpacer" TargetType="RowDefinition">
            <Setter Property="Height" Value="8"/>
        </Style>
    </Window.Resources>

    <!-- Outer border gives the window its themed frame. -->
    <Border BorderBrush="{StaticResource OeBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>    <!-- custom title bar -->
                <RowDefinition Height="*"/>     <!-- page content -->
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0" Background="{StaticResource OeSurface1Brush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Image Source="pack://application:,,,/favicon.ico" Width="16" Height="16"
                           VerticalAlignment="Center" Margin="0,0,10,0"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="TxtWindowTitle"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource OeTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Header actions: ghost-styled Open/Save buttons + caption buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <CheckBox x:Name="ChkExperimentalEnabled"
                              Content="Experimental ⚗"
                              VerticalAlignment="Center" Margin="0,0,12,0"
                              ToolTip="Show experimental features. Generated templates may behave unpredictably."
                              Checked="ChkExperimentalEnabled_Changed"
                              Unchecked="ChkExperimentalEnabled_Changed"/>
                    <Button Content="New" Click="BtnNew_Click" Style="{StaticResource OeGhostButton}" ToolTip="Reset settings (Ctrl+N)"/>
                    <Button Content="Open…" Click="BtnOpen_Click" Style="{StaticResource OeGhostButton}" ToolTip="Open settings (Ctrl+O)"/>
                    <Button Content="Save" Click="BtnSave_Click" Style="{StaticResource OeGhostButton}" ToolTip="Save settings (Ctrl+S)"/>
                    <Button Content="Save as…" Click="BtnSaveAs_Click" Style="{StaticResource OeGhostButton}" ToolTip="Save settings as (Ctrl+Shift+S)" Margin="0,0,8,0"/>
                    <Button Content="—" Style="{StaticResource TitleBarButton}" ToolTip="Minimize" Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnMaximize" Content="▢" Style="{StaticResource TitleBarButton}" ToolTip="Maximize" Click="BtnMaximize_Click"/>
                    <Button Content="✕" Style="{StaticResource TitleBarCloseButton}" ToolTip="Close" Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- Page content: 220px nav | 1fr settings | 320px preview, with WIP banner above. -->
            <Grid Grid.Row="1" Margin="20,16,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- WIP warning -->
                    <RowDefinition Height="Auto"/>  <!-- spacer -->
                    <RowDefinition Height="*"/>     <!-- shell -->
                </Grid.RowDefinitions>

                <!-- WIP warning: amber left bar, surface bg, no decorative border. -->
                <Border Grid.Row="0"
                        Background="{StaticResource OeWarnBgBrush}"
                        BorderBrush="{StaticResource OeAccentBrush}"
                        BorderThickness="3,0,0,0"
                        Padding="14,10"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Vertical">
                        <TextBlock x:Name="TxtWipWarning"
                                   Foreground="{StaticResource OeTextBrush}"
                                   FontSize="13" TextWrapping="Wrap"/>
                        <TextBlock Foreground="{StaticResource OeTextDimBrush}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0">
                            Prefer the browser?
                            <Hyperlink x:Name="LinkWebVersion"
                                       NavigateUri="https://rannes.github.io/Olden-Era---Template-Generator/"
                                       Foreground="{StaticResource OeAccentBrush}"
                                       RequestNavigate="LinkWebVersion_RequestNavigate">Try the web version</Hyperlink>.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Three-column shell: nav | content | preview -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Section nav: ListBox driving which panel is visible. -->
                    <ListBox Grid.Column="0"
                             x:Name="LstNav"
                             Background="Transparent"
                             BorderThickness="0"
                             Focusable="True"
                             KeyboardNavigation.TabNavigation="Once"
                             SelectionChanged="LstNav_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="{StaticResource OeTextDimBrush}"/>
                                <Setter Property="FontFamily" Value="{StaticResource OeFont}"/>
                                <Setter Property="FontSize"   Value="13"/>
                                <Setter Property="Padding"    Value="12,8"/>
                                <Setter Property="Margin"     Value="0,1"/>
                                <Setter Property="Cursor"     Value="Hand"/>
                                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                <Setter Property="BorderBrush"     Value="Transparent"/>
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource OeSurface2Brush}"/>
                                                    <Setter Property="Foreground"                  Value="{StaticResource OeTextBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"  Value="{StaticResource OeSurface2Brush}"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource OeAccentBrush}"/>
                                                    <Setter Property="Foreground"                  Value="{StaticResource OeTextBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBoxItem Content="Map"            Tag="Map"     IsSelected="True"/>
                        <ListBoxItem Content="Heroes"         Tag="Heroes"/>
                        <ListBoxItem Content="Topology"       Tag="Topology"/>
                        <ListBoxItem Content="Zones"          Tag="Zones"/>
                        <ListBoxItem Content="Win Conditions" Tag="WinConditions"/>
                        <ListBoxItem x:Name="LstNavExperimental" Content="Experimental ⚗" Tag="Experimental" Visibility="Collapsed"/>
                    </ListBox>

                    <!-- Content column: each panel always exists for code-behind compatibility,
                         but only one is Visible at a time. LstNav_SelectionChanged toggles them. -->
                    <Grid Grid.Column="2">
                        <views:MapPanel             x:Name="PnlMap"        Visibility="Visible"/>
                        <views:HeroesPanel          x:Name="PnlHeroes"     Visibility="Collapsed"/>
                        <views:TopologyPanel        x:Name="PnlTopology"   Visibility="Collapsed"/>
                        <views:ZonesPanel           x:Name="PnlZones"      Visibility="Collapsed"/>
                        <views:WinConditionsPanel   x:Name="PnlGameRules"  Visibility="Collapsed"/>
                        <views:ExperimentalPanel    x:Name="PnlExperimental" Visibility="Collapsed"/>
                    </Grid>

                    <!-- Preview column. -->
                    <Grid Grid.Column="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- generate button -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>   <!-- validation -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>      <!-- image -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>   <!-- outdated warning -->
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>   <!-- show preview checkbox -->
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>   <!-- save button -->
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                x:Name="BtnPreview"
                                Content="Generate Template"
                                Style="{StaticResource GenerateButton}"
                                HorizontalAlignment="Stretch"
                                Click="BtnPreview_Click"/>

                        <TextBlock Grid.Row="2"
                                   x:Name="TxtValidation"
                                   Foreground="{StaticResource OeErrorBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Stretch" TextAlignment="Center"/>

                        <Border Grid.Row="4"
                                BorderThickness="1"
                                CornerRadius="6"
                                BorderBrush="{StaticResource OeBorderBrush}"
                                Background="{StaticResource OeSurface1Brush}"
                                Padding="6">
                            <Image x:Name="ImgPreview"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Grid.Row="6"
                                   x:Name="TxtOutdatedWarning"
                                   Foreground="{StaticResource OeErrorBrush}"
                                   FontSize="12" TextWrapping="Wrap"
                                   Visibility="Hidden"
                                   HorizontalAlignment="Stretch" TextAlignment="Center"
                                   Text="Settings changed — regenerate before saving."/>

                        <CheckBox Grid.Row="8"
                                  x:Name="ChkSavePreviewImage"
                                  Content="Show preview in-game"
                                  IsChecked="True"
                                  HorizontalAlignment="Left"/>

                        <Button Grid.Row="10"
                                x:Name="BtnSaveGenerated"
                                Content="Save Template"
                                Style="{StaticResource GenerateButton}"
                                HorizontalAlignment="Stretch"
                                IsEnabled="False"
                                Click="BtnSaveGenerated_Click"/>
                    </Grid>
                </Grid>

                <!-- Hidden combos still required by code-behind. -->
                <ComboBox x:Name="CmbGameMode" Visibility="Collapsed"/>
                <TextBlock x:Name="TxtAppTitle" Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Border>
</Window>
